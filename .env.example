# JWT_SECRET: JWT tokenlarni imzolash uchun maxfiy kalit.
JWT_SECRET="your_jwt_secret_here"

# STRIPE_SECRET_KEY: Stripe to'lov tizimi uchun maxfiy kalit.
STRIPE_SECRET_KEY="sk_test_..."

# STRIPE_WEBHOOK_SECRET: Stripe webhooklarini tekshirish uchun kalit.
STRIPE_WEBHOOK_SECRET="whsec_..."

# STRIPE_PRICE_ID_MONTHLY: Stripe Dashboard-dan olingan oylik tarif narxi ID.
STRIPE_PRICE_ID_MONTHLY="price_..."

# STRIPE_PRICE_ID_LIFETIME: Stripe Dashboard-dan olingan bir martalik tarif narxi ID.
STRIPE_PRICE_ID_LIFETIME="price_..."

# GEMINI_API_KEY: AI Focus Analyzer uchun Gemini API kaliti.
GEMINI_API_KEY="your_gemini_api_key"

# APP_URL: Ilova manzili (masalan, https://fasttime.vercel.app).
APP_URL="http://localhost:3000"

# DEV_BYPASS_WEAK_PASSWORD: Test hisoblar uchun kuchsiz parollarga ruxsat berish (true/false).
DEV_BYPASS_WEAK_PASSWORD=false
